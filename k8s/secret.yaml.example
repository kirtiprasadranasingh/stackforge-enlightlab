apiVersion: v1
kind: Namespace
metadata:
  name: stackforge
---
apiVersion: v1
kind: Secret
metadata:
  name: stackforge-secrets
  namespace: stackforge
type: Opaque
stringData:
  # Replace before apply — do not commit real values
  GEMINI_API_KEY: "REPLACE_ME"
  NEXT_PUBLIC_APP_URL: "https://REPLACE_WITH_LOAD_BALANCER_OR_DOMAIN"
  NEXT_PUBLIC_DIAGNOSTIC_URL: "https://enlightlabs.com/contact"
  ALLOWED_ORIGINS: "https://REPLACE_WITH_LOAD_BALANCER_OR_DOMAIN"
  NODE_ENV: "production"
