# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example
k8s/secret.yaml


# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local QA / verify dumps — never commit providers or node_modules
.verify-*/
.review-*/
.verify-*/
_qa_*/
temp-zip/
**/node_modules/
**/.terraform/
**/.terraform.lock.hcl
*.exe
.last-deploy-tag

# Large / generated local artifacts
StackForge_*.pdf
StackForge_*.html
scripts/_debug-*
scripts/_test-*
