# StackForge Environment Configuration

# Required: Google Gemini API key
# Get one from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Soft CTA — paid diagnostic / contact
NEXT_PUBLIC_DIAGNOSTIC_URL=https://enlightlabs.com/contact

# Optional on Vercel — auto-detected from VERCEL_URL if unset
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Extra allowed origins (comma-separated). Vercel *.vercel.app allowed automatically on Vercel.
# ALLOWED_ORIGINS=https://stackforge.enlightlab.com

# Force-allow Vercel preview origins even off-Vercel hosts
# ALLOW_VERCEL_ORIGINS=true

# Optional: forward leads to your CRM
# LEAD_CAPTURE_ENDPOINT=https://your-crm.com/api/leads

# Rate limit
# RATE_LIMIT_REQUESTS=8
# RATE_LIMIT_WINDOW_SEC=60
